cat > .gitignore << 'EOF'
# Зависимости
**/node_modules/
**/__pycache__/
**/*.pyc
**/venv/
**/env/
**/.env
**/package-lock.json

# Сборка
**/dist/
**/dist-ssr/
**/build/

# Базы данных
**/*.sqlite3
**/*.db

# Docker
**/docker-compose.override.yml

# Логи
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Секреты
**/.env
**/.env.local
**/.env.*.local

# Django
**/staticfiles/
**/media/
**/migrations/  # Кроме __init__.py

# Python
**/*.pyc
**/__pycache__/
**/instance/
**/.pytest_cache/
**/.coverage
**/htmlcov/
EOF